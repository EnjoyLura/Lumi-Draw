{
  "name": "lumi-draw",
  "version": "0.1.0",
  "private": true,
  "packageManager": "pnpm@11.7.0",
  "scripts": {
    "dev:mobile": "pnpm --filter @lumi-draw/mobile dev:mp-weixin",
    "dev:mobile:h5": "pnpm --filter @lumi-draw/mobile dev:h5",
    "build:mobile": "pnpm --filter @lumi-draw/mobile build:mp-weixin",
    "verify:mini-program-release": "pnpm build:mobile && node scripts/check-mini-program-release.mjs",
    "build:mobile:simulator": "pnpm --filter @lumi-draw/mobile build:mp-weixin:simulator",
    "build:mobile:h5": "pnpm --filter @lumi-draw/mobile build:h5",
    "dev:admin": "pnpm --filter @lumi-draw/admin dev",
    "build:admin": "pnpm --filter @lumi-draw/admin build",
    "dev:api": "pnpm --filter @lumi-draw/api dev",
    "build:api": "pnpm --filter @lumi-draw/api build",
    "start:api": "pnpm --filter @lumi-draw/api start",
    "typecheck": "pnpm -r typecheck",
    "check:mobile-routes": "node scripts/check-mobile-routes.mjs",
    "check:mobile-features": "node scripts/check-mobile-feature-contracts.mjs",
    "check:admin-features": "node scripts/check-admin-feature-contracts.mjs",
    "check:production-safety": "node scripts/check-production-safety.mjs",
    "verify:static": "pnpm check:mobile-routes && pnpm check:mobile-features && pnpm check:admin-features && pnpm typecheck && pnpm build:api && pnpm build:admin && pnpm build:mobile:h5 && git diff --check",
    "verify:ui": "pnpm build:mobile:h5 && pnpm build:admin && playwright test",
    "verify:api": "pnpm smoke:api",
    "verify:full": "pnpm verify:static && pnpm verify:api && pnpm verify:ui",
    "verify:acceptance": "node scripts/verify-acceptance.mjs",
    "audit:mobile-visuals": "pnpm build:mobile:h5 && node scripts/audit-mobile-visuals.mjs",
    "smoke:api": "node scripts/smoke-api.mjs",
    "smoke:mobile-real-h5": "node scripts/smoke-mobile-real-h5.mjs",
    "smoke:admin-real-ui": "node scripts/smoke-admin-real-ui.mjs"
  },
  "devDependencies": {
    "@playwright/test": "^1.61.1",
    "typescript": "5.4.5"
  }
}
