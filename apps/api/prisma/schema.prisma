// Lumi Draw API - Prisma schema
// 本增分聚焦「只读配置」相关模型，后续增分再补 User/Work/Generate 等核心表。

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// 走马灯 Banner
model Banner {
  id          Int      @id @default(autoincrement())
  title       String
  description String
  action      String   @default("")
  sort        Int      @default(0)
  enabled     Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@map("banners")
}

// 玩法模板 Gameplay
model Gameplay {
  id          Int      @id @default(autoincrement())
  name        String
  description String
  uses        String   @default("")
  hot         Boolean  @default(false)
  enabled     Boolean  @default(true)
  sort        Int      @default(0)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@map("gameplays")
}

// 风格 Style
model Style {
  id        Int      @id @default(autoincrement())
  name      String
  prompt    String
  uses      Int      @default(0)
  enabled   Boolean  @default(true)
  sort      Int      @default(0)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("styles")
}

// 分类 Category
model Category {
  id        Int      @id @default(autoincrement())
  name      String
  count     Int      @default(0)
  sort      Int      @default(0)
  enabled   Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("categories")
}

// 热搜 HotSearch
model HotSearch {
  id        Int      @id @default(autoincrement())
  keyword   String
  hot       Int      @default(0)
  top       Boolean  @default(false)
  enabled   Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("hot_searches")
}

// AI 模型配置 ModelConfig
model ModelConfig {
  id                   String   @id
  provider             String   @default("kie")
  providerModel        String
  name                 String
  description          String
  tags                 String[]
  costCredits          Int      @default(0)
  badge                String   @default("")
  supportsTextToImage  Boolean  @default(true)
  supportsImageToImage Boolean  @default(true)
  enabled              Boolean  @default(true)
  sort                 Int      @default(0)
  createdAt            DateTime @default(now())
  updatedAt            DateTime @updatedAt

  @@map("model_configs")
}

// 分辨率配置 QualityConfig
model QualityConfig {
  id         Int      @id @default(autoincrement())
  label      String
  pixel      String
  multiplier Float    @default(1)
  enabled    Boolean  @default(true)
  sort       Int      @default(0)
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  @@map("quality_configs")
}

// 尺寸比例 RatioConfig
model RatioConfig {
  id          Int      @id @default(autoincrement())
  label       String
  description String
  enabled     Boolean  @default(true)
  sort        Int      @default(0)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@map("ratio_configs")
}

// 充值方案 RechargeTier
model RechargeTier {
  id        Int      @id @default(autoincrement())
  price     Int
  credits   Int
  bonus     Int      @default(0)
  enabled   Boolean  @default(true)
  sort      Int      @default(0)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("recharge_tiers")
}

// 会员方案 MemberPlan
model MemberPlan {
  id           Int      @id @default(autoincrement())
  name         String
  price        Int
  rights       String
  giftCredits  Int      @default(0)
  checkinBonus Int      @default(0)
  enabled      Boolean  @default(true)
  sort         Int      @default(0)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  @@map("member_plans")
}

// 协议 Agreement（user / privacy / membership）
model Agreement {
  type      String   @id
  title     String
  content   String
  updatedAt DateTime @updatedAt

  @@map("agreements")
}

// 更新日志 / 版本 AppVersion
model AppVersion {
  id         Int      @id @default(autoincrement())
  version    String
  releasedAt String
  items      Json
  sort       Int      @default(0)
  createdAt  DateTime @default(now())

  @@map("versions")
}

// 键值配置 AppSetting（reviewMode / manualReviewEnabled 等）
model AppSetting {
  key       String   @id
  value     String
  updatedAt DateTime @updatedAt

  @@map("app_settings")
}

// 用户 User
model User {
  id          Int      @id @default(autoincrement())
  openId      String?  @unique
  nickname    String
  avatarText  String   @default("")
  avatarColor String   @default("#5B9FE8")
  avatarUrl   String?
  bio         String   @default("")
  gender      String   @default("unknown") // unknown | male | female
  credits        Int       @default(0)
  memberPlan     String    @default("") // "" | 月卡 | 季卡 | 年卡
  memberExpireAt DateTime?
  status         String    @default("normal") // normal | banned
  phone          String    @default("")
  inviteCode     String?   @unique
  invitedById    Int?
  worksCount  Int      @default(0)
  likesCount  Int      @default(0)
  followers   Int      @default(0)
  following   Int      @default(0)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  works              Work[]
  generateJobs       GenerateJob[]
  refreshTokens      RefreshToken[]
  creditTransactions CreditTransaction[]
  checkinRecords     CheckinRecord[]

  @@map("users")
}

// 举报 Report
model Report {
  id          Int       @id @default(autoincrement())
  workId      Int
  reporterId  Int
  reason      String
  description String    @default("")
  status      String    @default("pending") // pending | processing | resolved | ignored
  createdAt   DateTime  @default(now())
  handledAt   DateTime?

  @@index([status])
  @@map("reports")
}

// 用户反馈 Feedback
model Feedback {
  id        Int      @id @default(autoincrement())
  userId    Int
  type      String
  content   String
  imageUrls String   @default("") // 逗号分隔
  wechat    String   @default("")
  status    String   @default("pending") // pending | processing | resolved | ignored
  reply     String   @default("")
  createdAt DateTime @default(now())

  @@index([status])
  @@map("feedback")
}

// 弹窗公告 Announcement
model Announcement {
  id        Int      @id @default(autoincrement())
  title     String
  summary   String   @default("")
  action    String   @default("")
  popup     Boolean  @default(false)
  rangeText String   @default("")
  enabled   Boolean  @default(true)
  createdAt DateTime @default(now())

  @@map("announcements")
}

// 系统通知 Push
model Push {
  id        Int       @id @default(autoincrement())
  title     String
  content   String
  target    String    @default("全部用户")
  status    String    @default("draft") // draft | sent | revoked
  sentAt    DateTime?
  createdAt DateTime  @default(now())

  @@map("pushes")
}

// 站内信 Notification
model Notification {
  id        Int      @id @default(autoincrement())
  userId    Int
  title     String
  content   String   @default("")
  type      String   @default("system")
  read      Boolean  @default(false)
  createdAt DateTime @default(now())

  @@index([userId])
  @@map("notifications")
}

// 敏感词 SensitiveWord
// Work like / favorite state.
model WorkInteraction {
  id        Int      @id @default(autoincrement())
  userId    Int
  workId    Int
  type      String   // like | favorite
  createdAt DateTime @default(now())

  @@unique([userId, workId, type])
  @@index([userId, type])
  @@index([workId, type])
  @@map("work_interactions")
}

// User browsing history.
model WorkView {
  id        Int      @id @default(autoincrement())
  userId    Int
  workId    Int
  viewedAt  DateTime @default(now())
  createdAt DateTime @default(now())

  @@unique([userId, workId])
  @@index([userId, viewedAt])
  @@map("work_views")
}

// User follow relationship.
model Follow {
  id          Int      @id @default(autoincrement())
  followerId  Int
  followingId Int
  createdAt   DateTime @default(now())

  @@unique([followerId, followingId])
  @@index([followerId])
  @@index([followingId])
  @@map("follows")
}

model SensitiveWord {
  id        Int      @id @default(autoincrement())
  word      String   @unique
  createdAt DateTime @default(now())

  @@map("sensitive_words")
}

// 邀请记录 InviteRecord
model InviteRecord {
  id            Int      @id @default(autoincrement())
  inviterId     Int
  inviteeId     Int      @unique
  rewardInviter Int      @default(0)
  rewardInvitee Int      @default(0)
  createdAt     DateTime @default(now())

  @@index([inviterId])
  @@map("invite_records")
}

// 积分流水 CreditTransaction
model CreditTransaction {
  id           Int      @id @default(autoincrement())
  userId       Int
  user         User     @relation(fields: [userId], references: [id])
  type         String   // recharge | consume | refund | checkin | invite | membership | adjust
  amount       Int      // 正数入账，负数消费
  balanceAfter Int
  reason       String   @default("")
  refId        String   @default("")
  createdAt    DateTime @default(now())

  @@index([userId])
  @@map("credit_transactions")
}

// 签到记录 CheckinRecord
model CheckinRecord {
  id             Int      @id @default(autoincrement())
  userId         Int
  user           User     @relation(fields: [userId], references: [id])
  date           String   // YYYY-MM-DD
  credits        Int
  continuousDays Int
  createdAt      DateTime @default(now())

  @@unique([userId, date])
  @@index([userId])
  @@map("checkin_records")
}

// 刷新令牌 RefreshToken（存哈希）
model RefreshToken {
  id        Int      @id @default(autoincrement())
  userId    Int
  user      User     @relation(fields: [userId], references: [id])
  tokenHash String   @unique
  expiresAt DateTime
  revoked   Boolean  @default(false)
  createdAt DateTime @default(now())

  @@index([userId])
  @@map("refresh_tokens")
}

// 管理员 AdminUser
model AdminUser {
  id           Int      @id @default(autoincrement())
  username     String   @unique
  passwordHash String
  nickname     String   @default("管理员")
  role         String   @default("super_admin") // super_admin | operator | auditor | finance
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  @@map("admin_users")
}

// 作品 Work
model Work {
  id          Int      @id @default(autoincrement())
  userId      Int
  user        User     @relation(fields: [userId], references: [id])
  title       String
  description String   @default("")
  prompt      String   @default("")
  imageUrl    String   @default("")
  ratio       String   @default("1:1")
  quality     String   @default("1K")
  modelId     String   @default("")
  style       String   @default("")
  status      String   @default("published") // draft | pending | published | rejected | offline
  isPublic    Boolean  @default(true)
  featured    Boolean  @default(false)
  recommend   Boolean  @default(false)
  likes       Int      @default(0)
  favorites   Int      @default(0)
  remakes     Int      @default(0)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([status])
  @@index([userId])
  @@map("works")
}

// AI generation task.
model GenerateJob {
  id            String   @id @default(cuid())
  userId        Int
  user          User     @relation(fields: [userId], references: [id])
  mode          String   // text-to-image | image-to-image
  modelId       String
  provider      String   @default("kie")
  providerModel String   @default("")
  prompt        String
  inputImageUrl String   @default("")
  gameplayId    Int?
  style         String   @default("")
  ratio         String
  quality       String
  count         Int
  costCredits   Int
  refundCredits Int      @default(0)
  status        String   @default("queued") // queued | running | succeeded | partial_failed | failed | cancelled
  progress      Int      @default(0)
  stageText     String   @default("")
  kieTaskId     String?  @unique
  errorMessage  String   @default("")
  retryOfJobId  String?
  cancelledAt   DateTime?
  startedAt     DateTime?
  finishedAt    DateTime?
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  results GenerateResult[]

  @@index([userId, createdAt])
  @@index([status, createdAt])
  @@map("generate_jobs")
}

// AI generation output.
model GenerateResult {
  id           String   @id @default(cuid())
  jobId        String
  job          GenerateJob @relation(fields: [jobId], references: [id], onDelete: Cascade)
  status       String   @default("succeeded") // succeeded | failed
  imageUrl     String   @default("")
  width        Int?
  height       Int?
  sizeBytes    Int?
  ossKey       String   @default("")
  errorMessage String   @default("")
  workId       Int?
  createdAt    DateTime @default(now())

  @@index([jobId])
  @@map("generate_results")
}
