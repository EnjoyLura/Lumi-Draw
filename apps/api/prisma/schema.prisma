// Lumi Draw API - Prisma schema
// 本增分聚焦「只读配置」相关模型，后续增分再补 User/Work/Generate 等核心表。

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// 走马灯 Banner
model Banner {
  id          Int      @id @default(autoincrement())
  title       String
  description String
  action      String   @default("")
  sort        Int      @default(0)
  enabled     Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@map("banners")
}

// 玩法模板 Gameplay
model Gameplay {
  id          Int      @id @default(autoincrement())
  name        String
  description String
  uses        String   @default("")
  hot         Boolean  @default(false)
  enabled     Boolean  @default(true)
  sort        Int      @default(0)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@map("gameplays")
}

// 风格 Style
model Style {
  id        Int      @id @default(autoincrement())
  name      String
  prompt    String
  uses      Int      @default(0)
  enabled   Boolean  @default(true)
  sort      Int      @default(0)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("styles")
}

// 分类 Category
model Category {
  id        Int      @id @default(autoincrement())
  name      String
  count     Int      @default(0)
  sort      Int      @default(0)
  enabled   Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("categories")
}

// 热搜 HotSearch
model HotSearch {
  id        Int      @id @default(autoincrement())
  keyword   String
  hot       Int      @default(0)
  top       Boolean  @default(false)
  enabled   Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("hot_searches")
}

// AI 模型配置 ModelConfig
model ModelConfig {
  id                   String   @id
  provider             String   @default("kie")
  providerModel        String
  name                 String
  description          String
  tags                 String[]
  costCredits          Int      @default(0)
  badge                String   @default("")
  supportsTextToImage  Boolean  @default(true)
  supportsImageToImage Boolean  @default(true)
  enabled              Boolean  @default(true)
  sort                 Int      @default(0)
  createdAt            DateTime @default(now())
  updatedAt            DateTime @updatedAt

  @@map("model_configs")
}

// 分辨率配置 QualityConfig
model QualityConfig {
  id         Int      @id @default(autoincrement())
  label      String
  pixel      String
  multiplier Float    @default(1)
  enabled    Boolean  @default(true)
  sort       Int      @default(0)
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  @@map("quality_configs")
}

// 尺寸比例 RatioConfig
model RatioConfig {
  id          Int      @id @default(autoincrement())
  label       String
  description String
  enabled     Boolean  @default(true)
  sort        Int      @default(0)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@map("ratio_configs")
}

// 充值方案 RechargeTier
model RechargeTier {
  id        Int      @id @default(autoincrement())
  price     Int
  credits   Int
  bonus     Int      @default(0)
  enabled   Boolean  @default(true)
  sort      Int      @default(0)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("recharge_tiers")
}

// 会员方案 MemberPlan
model MemberPlan {
  id           Int      @id @default(autoincrement())
  name         String
  price        Int
  rights       String
  giftCredits  Int      @default(0)
  checkinBonus Int      @default(0)
  enabled      Boolean  @default(true)
  sort         Int      @default(0)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  @@map("member_plans")
}

// 协议 Agreement（user / privacy / membership）
model Agreement {
  type      String   @id
  title     String
  content   String
  updatedAt DateTime @updatedAt

  @@map("agreements")
}

// 更新日志 / 版本 AppVersion
model AppVersion {
  id         Int      @id @default(autoincrement())
  version    String
  releasedAt String
  items      Json
  sort       Int      @default(0)
  createdAt  DateTime @default(now())

  @@map("versions")
}

// 键值配置 AppSetting（reviewMode / manualReviewEnabled 等）
model AppSetting {
  key       String   @id
  value     String
  updatedAt DateTime @updatedAt

  @@map("app_settings")
}

// 用户 User
model User {
  id          Int      @id @default(autoincrement())
  openId      String?  @unique
  nickname    String
  avatarText  String   @default("")
  avatarColor String   @default("#5B9FE8")
  avatarUrl   String?
  bio         String   @default("")
  gender      String   @default("unknown") // unknown | male | female
  credits     Int      @default(0)
  memberPlan  String   @default("") // "" | 月卡 | 季卡 | 年卡
  status      String   @default("normal") // normal | banned
  phone       String   @default("")
  worksCount  Int      @default(0)
  likesCount  Int      @default(0)
  followers   Int      @default(0)
  following   Int      @default(0)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  works Work[]

  @@map("users")
}

// 作品 Work
model Work {
  id          Int      @id @default(autoincrement())
  userId      Int
  user        User     @relation(fields: [userId], references: [id])
  title       String
  description String   @default("")
  prompt      String   @default("")
  imageUrl    String   @default("")
  ratio       String   @default("1:1")
  quality     String   @default("1K")
  modelId     String   @default("")
  style       String   @default("")
  status      String   @default("published") // draft | pending | published | rejected | offline
  isPublic    Boolean  @default(true)
  featured    Boolean  @default(false)
  recommend   Boolean  @default(false)
  likes       Int      @default(0)
  favorites   Int      @default(0)
  remakes     Int      @default(0)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([status])
  @@index([userId])
  @@map("works")
}
